# Instagram Credentials for Prototype
IG_USERNAME=your_username
IG_PASSWORD=your_password

# Proxy (Required for scale, optional for local test)
# Format: http://username:password@proxy_ip:port
IG_PROXY=

# Supabase (For Dashboard Connection)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (Used by Python backend for admin operations)
# Found in: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=
